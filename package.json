{
	"name": "@numbered/create-bootstrap",
	"version": "1.0.5",
	"description": "Scaffold a new Numbered Studio project (Next.js + Sanity or Shopify Liquid) with full Sanity/GitHub/Vercel setup.",
	"type": "module",
	"bin": {
		"create-bootstrap": "./bin/index.js"
	},
	"files": [
		"bin",
		"src"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Numbered-com/create-bootstrap.git"
	},
	"scripts": {
		"dev": "node bin/index.js",
		"release": "npm version patch",
		"release:minor": "npm version minor",
		"release:major": "npm version major",
		"postversion": "git push --follow-tags"
	},
	"dependencies": {
		"@clack/prompts": "^1.2.0",
		"picocolors": "^1.1.1"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"engines": {
		"node": ">=22"
	}
}
